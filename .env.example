# =============================================================================
# db-hygiene-scanner Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- AI API Configuration ---
# Required: Anthropic API key for Claude AI integration
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- GitHub Integration ---
# Optional: GitHub personal access token for repository access and PR creation
# Required scopes: repo, workflow, pull-requests:write
GITHUB_TOKEN=

# Target repository in owner/repo format (e.g., acme-bank/payment-service)
GITHUB_REPO=

# GitHub username or email for PR review assignment
GITHUB_REVIEWER=

# --- Scan Configuration ---
# Local path to scan (defaults to /app/src for containerized deployments)
SCAN_TARGET_PATH=/app/src

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- AI Model Selection ---
# Model used for scan classification (fast, cost-effective)
AI_MODEL_SCAN=claude-sonnet-4-6

# Model used for fix generation (high quality)
AI_MODEL_FIX=claude-opus-4-6

# Model used for security review (high quality)
AI_MODEL_REVIEW=claude-opus-4-6

# --- Performance Limits ---
# Maximum file size in KB to process (files larger than this are skipped)
MAX_FILE_SIZE_KB=500

# API rate limit: maximum requests per minute to Anthropic API
RATE_LIMIT_RPM=30

# --- Database Platform Configuration ---
# Comma-separated list of MongoDB variant identifiers
MONGODB_PLATFORMS=MONGODB,EDB_YUGABYTE

# --- Security ---
# Comma-separated regex patterns to strip from code before sending to AI
# These patterns remove sensitive data (API keys, passwords, connection strings)
SECURITY_STRIP_PATTERNS=(?i)(api[_-]?key|apikey)\s*[=:]\s*['"]?[a-zA-Z0-9\-_.]+['"]?,(?i)(password|passwd|pwd)\s*[=:]\s*['"]?[^'";]+['"]?,(?i)(connection[_-]?string|server|host)\s*[=:]\s*['"]?[^'";]+['"]?
